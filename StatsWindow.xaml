<ui:FluentWindow x:Class="SedentaryReminder.StatsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="久坐提醒 · 统计"
                 Icon="pack://application:,,,/app.ico"
                 Width="420"
                 Height="560"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="久坐提醒 · 统计" />

        <StackPanel Grid.Row="1" Margin="24,12,24,20">

            <TextBlock Text="今日" FontSize="16" FontWeight="SemiBold" />

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Margin="0,0,4,8" Padding="14,12"
                        CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="久坐时长" FontSize="12" Opacity="0.7" />
                        <TextBlock x:Name="SittingValue" Text="0 分钟" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Margin="4,0,0,8" Padding="14,12"
                        CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="提醒次数" FontSize="12" Opacity="0.7" />
                        <TextBlock x:Name="RemindersValue" Text="0" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Margin="0,0,4,0" Padding="14,12"
                        CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="完成休息" FontSize="12" Opacity="0.7" />
                        <TextBlock x:Name="DoneValue" Text="0" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Margin="4,0,0,0" Padding="14,12"
                        CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="跳过休息" FontSize="12" Opacity="0.7" />
                        <TextBlock x:Name="SkippedValue" Text="0" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="近 7 天久坐时长" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,10" />

            <!-- 柱状图由代码动态生成：每列 = 数值标签 + 柱体 + 日期标签 -->
            <Grid x:Name="ChartGrid" Height="170" />

        </StackPanel>
    </Grid>
</ui:FluentWindow>
