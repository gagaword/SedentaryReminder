<Window x:Class="SedentaryReminder.BreakOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF3DDC97" Offset="0" />
            <GradientStop Color="#FF0E9E83" Offset="0.55" />
            <GradientStop Color="#FF0A7D68" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="🧍 起来活动一下"
                       FontSize="44"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Opacity="0.95"
                       HorizontalAlignment="Center" />

            <!-- 进度环 + 居中倒计时 -->
            <Grid Width="300" Height="300" Margin="0,20,0,20" HorizontalAlignment="Center">
                <Ellipse Width="300" Height="300"
                         Stroke="#33FFFFFF"
                         StrokeThickness="12" />
                <Path x:Name="ProgressArc"
                      Stroke="White"
                      StrokeThickness="12"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round" />
                <TextBlock x:Name="CountdownText"
                           Text="30"
                           FontSize="120"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <TextBlock Text="离开座位，舒展一下身体、远眺、喝口水"
                       FontSize="22"
                       Foreground="White"
                       Opacity="0.85"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <TextBlock x:Name="EscHint"
                   Text="长按 ESC 3 秒可提前退出"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,44"
                   FontSize="16"
                   Foreground="White"
                   Opacity="0.6" />
    </Grid>
</Window>
