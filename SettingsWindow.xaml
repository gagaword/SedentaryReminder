<ui:FluentWindow x:Class="SedentaryReminder.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="久坐提醒 · 设置"
                 Icon="pack://application:,,,/app.ico"
                 Width="420"
                 Height="470"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="久坐提醒 · 设置" />

        <StackPanel Grid.Row="1" Margin="24,12,24,0">

            <TextBlock Text="提醒间隔（分钟）" FontWeight="SemiBold" Margin="0,8,0,6" />
            <ui:NumberBox x:Name="IntervalBox"
                          Minimum="1"
                          Maximum="600"
                          SmallChange="5"
                          Value="45" />

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="开机自启" VerticalAlignment="Center" FontWeight="SemiBold" />
                <ui:ToggleSwitch x:Name="AutoStartSwitch" Grid.Column="1" />
            </Grid>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="启用提醒" VerticalAlignment="Center" FontWeight="SemiBold" />
                <ui:ToggleSwitch x:Name="EnabledSwitch" Grid.Column="1" IsChecked="True" />
            </Grid>

            <Border Margin="0,20,0,0" Padding="0,16,0,0" BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="强制模式（全屏提醒）" FontWeight="SemiBold" />
                            <TextBlock Text="到点全屏遮罩 · 长按 ESC 3 秒可退出"
                                       FontSize="12" Opacity="0.7" Margin="0,2,0,0" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="ForceModeSwitch" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="强制休息时长（秒）" FontWeight="SemiBold" Margin="0,16,0,6" />
                    <ui:NumberBox x:Name="RestSecondsBox"
                                  Minimum="5"
                                  Maximum="600"
                                  SmallChange="5"
                                  Value="30" />
                </StackPanel>
            </Border>

        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24,0,24,20">
            <ui:Button Content="取消" Margin="0,0,8,0" Click="OnCancel" />
            <ui:Button Content="保存" Appearance="Primary" Click="OnSave" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
